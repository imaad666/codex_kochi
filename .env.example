# Get your key at https://console.groq.com → API Keys
GROQ_API_KEY=

# Optional — defaults shown:
GROQ_PLANNER_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_WORKER_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MAX_OUTPUT_TOKENS=1600
GROQ_REQUEST_CHAR_BUDGET=7000
GROQ_TPM_SAFE_TOTAL=5500
GROQ_MIN_GAP_MS=700

# Local dev: sessions/runs persist under .open-ide/
# Vercel: connect a Blob store in the Vercel dashboard (auto-sets BLOB_READ_WRITE_TOKEN)

# GitHub OAuth (optional — enables Push to GitHub)
# Create app: https://github.com/settings/developers
# Dev callback:  http://localhost:3001/api/auth/github/callback
# Prod callback: https://YOUR-DOMAIN.vercel.app/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AUTH_SECRET=change-me-to-a-long-random-string

# Local dev
APP_URL=http://localhost:5173
API_URL=http://localhost:3001

# Production (set both to your Vercel URL, e.g. https://open-ide.vercel.app)
# APP_URL=https://your-app.vercel.app
# API_URL=https://your-app.vercel.app
