# Get your key at https://console.groq.com → API Keys
GROQ_API_KEY=

# Shared defaults (fallback when per-agent model not set)
GROQ_PLANNER_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_WORKER_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MAX_OUTPUT_TOKENS=1600
GROQ_REQUEST_CHAR_BUDGET=7000
GROQ_TPM_SAFE_TOTAL=5500
GROQ_MIN_GAP_MS=700

# Per-agent overrides (recommended — each card uses its own model)
# Leave API_KEY blank to use GROQ_API_KEY for that agent.
GROQ_ALTBOT_API_KEY=
GROQ_ALTBOT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_FRONTEND_API_KEY=
GROQ_FRONTEND_MODEL=llama-3.3-70b-versatile
GROQ_BACKEND_API_KEY=
GROQ_BACKEND_MODEL=qwen/qwen3-32b
GROQ_DATABASE_API_KEY=
GROQ_DATABASE_MODEL=llama-3.1-8b-instant

# Local dev: sessions/runs persist under .open-ide/
# Vercel: connect a Blob store (auto-sets BLOB_READ_WRITE_TOKEN)

# GitHub OAuth (optional — Push to GitHub)
# Dev callback:  http://localhost:3001/api/auth/github/callback
# Prod callback: https://YOUR-DOMAIN.vercel.app/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AUTH_SECRET=change-me-to-a-long-random-string

# Local dev
APP_URL=http://localhost:5173
API_URL=http://localhost:3001

# Production template: see .env.vercel.template
