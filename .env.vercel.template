# Open IDE — Vercel import template (codex-kochi)
# 1. Copy this file:  cp .env.vercel.template .env.vercel
# 2. Fill every value below (do NOT commit .env.vercel)
# 3. Vercel deploy screen → Environment Variables → Import .env → pick .env.vercel
#
# ── Groq: shared fallback (required) ─────────────────────────────────────────
# Create at https://console.groq.com/keys
GROQ_API_KEY=

# ── Per-agent overrides (optional — each card can use its own key + model) ───
# Leave API_KEY blank to use GROQ_API_KEY. Separate keys only help if different Groq accounts.
# TPM limits are per account — parallel swarm shares the same pool.
#
# Recommended for your free-tier limits:
#   Altbot     → llama-4-scout     (30K TPM — best for hyperreasoning JSON)
#   Frontend   → llama-3.3-70b     (12K TPM — stronger UI/layout code)
#   Backend    → qwen/qwen3-32b    (60 RPM — solid API/server code)
#   Database   → llama-3.1-8b      (6K TPM ok — SQL outputs are small)
#
# If you hit 429 rate limits during swarm, set ALL four to llama-4-scout.

# Altbot — hyperreasoning, orchestration, inspo search
GROQ_ALTBOT_API_KEY=
GROQ_ALTBOT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Ives UI — Frontend lane
GROQ_FRONTEND_API_KEY=
GROQ_FRONTEND_MODEL=llama-3.3-70b-versatile

# Jobalyser — Backend lane
GROQ_BACKEND_API_KEY=
GROQ_BACKEND_MODEL=qwen/qwen3-32b

# WzData — Database lane
GROQ_DATABASE_API_KEY=
GROQ_DATABASE_MODEL=llama-3.1-8b-instant

# ── Token budgets (shared — keep conservative on free tier) ───────────────────
GROQ_MAX_OUTPUT_TOKENS=1600
GROQ_REQUEST_CHAR_BUDGET=7000
GROQ_TPM_SAFE_TOTAL=5500
GROQ_MIN_GAP_MS=700

# ── NEW GitHub OAuth app (production only — do not reuse localhost app) ───────
# Create: https://github.com/settings/developers → New OAuth App
#   Name:        Open IDE (codex-kochi)
#   Homepage:    https://codex-kochi.vercel.app
#   Callback:    https://codex-kochi.vercel.app/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session cookie signing — generate: openssl rand -hex 32
AUTH_SECRET=

# ── Production URLs (same origin on Vercel) ─────────────────────────────────
APP_URL=https://codex-kochi.vercel.app
API_URL=https://codex-kochi.vercel.app

# BLOB_READ_WRITE_TOKEN — do NOT add here. Connect Blob store in Vercel dashboard.
